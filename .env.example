CONTABO_VPS_USER=root
CONTABO_VPS_PASSWORD=your_root_password_here
CONTABO_VPS_SSH_KEY_PATH=~/.ssh/greenscapes_contabo
CONTABO_VPS_WEB_ROOT=/var/www/greenscapes-va

